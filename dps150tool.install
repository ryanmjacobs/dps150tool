post_install() {
  cat <<'EOF'
==> dps150tool needs read/write access to the DPS150's USB serial device
    (usually /dev/ttyUSB0 or /dev/ttyACM0).

    Add your user to the 'uucp' group (Arch's serial-device group):

        sudo usermod -aG uucp "$USER"

    Then log out and back in for the change to take effect.
EOF
}

post_upgrade() {
  post_install
}
